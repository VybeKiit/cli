{
  "name": "vybekiit",
  "version": "0.3.0",
  "description": "Scaffold a VybeKiit template into your own repo: `npx vybekiit new web my-app`.",
  "license": "MIT",
  "packageManager": "pnpm@10.33.2",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "vybekiit": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "@inquirer/prompts": "^7.5.0",
    "@vybekiit/agent-kit": "workspace:*",
    "@vybekiit/core": "workspace:*",
    "@vybekiit/db": "workspace:*",
    "@vybekiit/deploy": "workspace:*",
    "@vybekiit/report-mode": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  }
}
